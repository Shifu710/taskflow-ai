{
  "name": "taskflow-ai",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/web",
    "build": "npm run build --workspace apps/web",
    "lint": "npm run lint --workspace apps/web",
    "typecheck": "npm run typecheck --workspace apps/web",
    "api:dev": "uvicorn app.main:app --reload --app-dir services/api",
    "api:test": "pytest services/api/app/tests",
    "api:lint": "ruff check services/api/app --select F",
    "api:migrate": "cd services/api && alembic upgrade head"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
